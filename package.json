{
  "name": "@axonivy/neo-root",
  "private": true,
  "version": "12.0.16-next",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "check": "pnpm run type && (pnpm run lint:ci || true) && pnpm run test:ci",
    "build:ci": "pnpm run build:editor && pnpm run build",
    "build": "react-router build",
    "build:editor": "pnpm run --filter @axonivy/neo-webview-process-editor build",
    "dev": "react-router dev",
    "dev:debug": "export DEBUG=vite:* && remix vite:dev",
    "serve": "vite preview",
    "openapi": "pnpm run openapi:download && pnpm run openapi:codegen",
    "openapi:codegen": "orval",
    "openapi:download": "mvn clean validate && curl -o target/market/openapi.json https://market.axonivy.com/stable/api-docs --create-dirs",
    "lint": "eslint",
    "lint:ci": "eslint -o eslint.xml -f checkstyle",
    "lint:fix": "eslint --fix",
    "lint:inspect": "eslint --inspect-config",
    "test": "vitest",
    "test:ci": "vitest run",
    "playwright": "pnpm run --filter playwright --",
    "type": "react-router typegen && tsc && pnpm run --filter @axonivy/neo-webview-process-editor type && pnpm run --filter @axonivy/neo-playwright type",
    "update:axonivy:next": "npx --yes npm-check-updates @axonivy* -w -c 0 --root -t semver -u",
    "sbom": "pnpm sbom --sbom-format cyclonedx --prod > bom.json",
    "sbom:dev": "pnpm sbom --sbom-format cyclonedx > bom-dev.json"
  },
  "dependencies": {
    "@axonivy/dataclass-editor": "~12.0.16-next.668.8d685ce",
    "@axonivy/dataclass-editor-protocol": "~12.0.16-next.668.8d685ce",
    "@axonivy/form-editor": "~12.0.16-next.965.de62011",
    "@axonivy/form-editor-core": "~12.0.16-next.965.de62011",
    "@axonivy/form-editor-protocol": "~12.0.16-next.965.de62011",
    "@axonivy/jsonrpc": "~12.0.16-next.766.6805716",
    "@axonivy/ui-components": "~12.0.16-next.766.6805716",
    "@axonivy/ui-icons": "~12.0.16-next.766.6805716",
    "@axonivy/variable-editor": "~12.0.16-next.837.68422e1",
    "@axonivy/variable-editor-protocol": "~12.0.16-next.837.68422e1",
    "@eclipse-glsp/protocol": "2.3.0",
    "@react-router/node": "^7.16.0",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "isbot": "^5.1.40",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.16.0",
    "vscode-jsonrpc": "8.2.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axonivy/eslint-config": "12.0.16-next.764.12fb0d3",
    "@react-router/dev": "^7.16.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.4",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@vanilla-extract/recipes": "^0.5.7",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "happy-dom": "^20.9.0",
    "orval": "8.17.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@axonivy/process-editor-inscription-protocol": "~12.0.16-next",
    "react-hotkeys-hook": "^4.6.1",
    "react-resizable-panels": "^2.1.7"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
