{
  "name": "@axonivy/neo-root",
  "private": true,
  "version": "14.0.0-next",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "check": "pnpm run type && (pnpm run lint:ci || true) && pnpm run test:ci  && pnpm run i18n:ci",
    "build:ci": "pnpm run build:editor && pnpm run i18n:collect && pnpm run build",
    "build": "react-router build",
    "build:editor": "pnpm run --filter @axonivy/neo-webview-process-editor build",
    "dev": "react-router dev",
    "dev:debug": "export DEBUG=vite:* && remix vite:dev",
    "serve": "vite preview",
    "openapi": "pnpm run openapi:download && pnpm run openapi:codegen",
    "openapi:codegen": "orval",
    "openapi:download": "mvn clean validate && curl -o target/market/openapi.json https://market.axonivy.com/stable/api-docs --create-dirs",
    "lint": "eslint",
    "lint:ci": "eslint -o eslint.xml -f checkstyle",
    "lint:fix": "eslint --fix",
    "lint:inspect": "eslint --inspect-config",
    "i18n": "pnpm run i18n:extract && pnpm run i18n:collect",
    "i18n:collect": "node --experimental-transform-types ./scripts/i18n-collect.ts",
    "i18n:extract": "i18next-cli extract",
    "i18n:ci": "i18next-cli extract --ci --dry-run",
    "test": "vitest",
    "test:ci": "vitest run",
    "playwright": "pnpm run --filter playwright --",
    "type": "react-router typegen && tsc && pnpm run --filter @axonivy/neo-webview-process-editor type && pnpm run --filter @axonivy/neo-playwright type",
    "update:axonivy:next": "pnpm update -r @axonivy",
    "sbom": "pnpm sbom --sbom-format cyclonedx --prod > bom.json",
    "sbom:dev": "pnpm sbom --sbom-format cyclonedx > bom-dev.json"
  },
  "dependencies": {
    "@axonivy/case-map-editor": "next-14.0.0",
    "@axonivy/case-map-editor-protocol": "next-14.0.0",
    "@axonivy/cms-editor": "next-14.0.0",
    "@axonivy/cms-editor-protocol": "next-14.0.0",
    "@axonivy/database-editor": "next-14.0.0",
    "@axonivy/database-editor-protocol": "next-14.0.0",
    "@axonivy/dataclass-editor": "next-14.0.0",
    "@axonivy/dataclass-editor-protocol": "next-14.0.0",
    "@axonivy/form-editor": "next-14.0.0",
    "@axonivy/form-editor-core": "next-14.0.0",
    "@axonivy/form-editor-protocol": "next-14.0.0",
    "@axonivy/jsonrpc": "next-14.0.0",
    "@axonivy/log-view": "next-14.0.0",
    "@axonivy/log-view-core": "next-14.0.0",
    "@axonivy/persistence-editor": "next-14.0.0",
    "@axonivy/persistence-editor-protocol": "next-14.0.0",
    "@axonivy/process-editor": "next-14.0.0",
    "@axonivy/process-editor-inscription-protocol": "next-14.0.0",
    "@axonivy/restclient-editor": "next-14.0.0",
    "@axonivy/restclient-editor-protocol": "next-14.0.0",
    "@axonivy/role-editor": "next-14.0.0",
    "@axonivy/role-editor-protocol": "next-14.0.0",
    "@axonivy/ui-components": "next-14.0.0",
    "@axonivy/ui-graph": "next-14.0.0",
    "@axonivy/ui-icons": "next-14.0.0",
    "@axonivy/user-editor": "next-14.0.0",
    "@axonivy/user-editor-protocol": "next-14.0.0",
    "@axonivy/variable-editor": "next-14.0.0",
    "@axonivy/variable-editor-protocol": "next-14.0.0",
    "@axonivy/webservice-editor": "next-14.0.0",
    "@axonivy/webservice-editor-protocol": "next-14.0.0",
    "@eclipse-glsp/protocol": "2.6.0",
    "@react-router/node": "^7.17.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-chained-backend": "^5.0.4",
    "i18next-http-backend": "^4.0.0",
    "i18next-resources-to-backend": "^1.2.1",
    "isbot": "^5.1.42",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-router": "^7.17.0",
    "vscode-jsonrpc": "8.2.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axonivy/eslint-config": "next-14.0.0",
    "@axonivy/prettier-config": "next-14.0.0",
    "@axonivy/ts-config": "next-14.0.0",
    "@react-router/dev": "^7.17.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/recipes": "^0.5.7",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.2",
    "i18next-cli": "^1.62.0",
    "orval": "8.18.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-compression2": "^2.5.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=24.11"
  },
  "workspaces": [
    "webviews/process-editor",
    "playwright"
  ],
  "prettier": "@axonivy/prettier-config"
}
