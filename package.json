{
  "name": "@axonivy/neo-root",
  "private": true,
  "version": "14.0.0-next",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "ci": "pnpm run ci:prepare && pnpm run type && (pnpm run lint:ci || true) && pnpm run test:ci  && pnpm run i18n:ci",
    "ci:prepare": "pnpm install --no-frozen-lockfile && pnpm run build:editor && pnpm run i18n:collect && pnpm run build",
    "build": "react-router build",
    "build:editor": "pnpm run --filter @axonivy/neo-webview-process-editor build",
    "dev": "react-router dev",
    "dev:debug": "export DEBUG=vite:* && remix vite:dev",
    "serve": "vite preview",
    "openapi": "pnpm run openapi:download && pnpm run openapi:codegen",
    "openapi:codegen": "orval",
    "openapi:download": "mvn clean validate && curl -o target/market/openapi.json https://market.axonivy.com/stable/api-docs --create-dirs",
    "lint": "eslint",
    "lint:ci": "eslint -o eslint.xml -f checkstyle",
    "lint:fix": "eslint --fix",
    "lint:inspect": "eslint --inspect-config",
    "i18n": "pnpm run i18n:extract && pnpm run i18n:collect",
    "i18n:collect": "node --experimental-transform-types ./scripts/i18n-collect.ts",
    "i18n:extract": "i18next-cli extract",
    "i18n:ci": "i18next-cli extract --ci --dry-run",
    "test": "vitest",
    "test:ci": "vitest run",
    "playwright": "pnpm run --filter playwright --",
    "type": "react-router typegen && tsc && pnpm run --filter @axonivy/neo-webview-process-editor type && pnpm run --filter @axonivy/neo-playwright type",
    "update:axonivy:next": "npx --yes npm-check-updates @axonivy* -w -c 0 --root -t semver -u",
    "sbom": "pnpm dlx @cyclonedx/cdxgen -t pnpm"
  },
  "dependencies": {
    "@axonivy/cms-editor": "~14.0.0-next.761.9cabfce",
    "@axonivy/cms-editor-protocol": "~14.0.0-next.761.9cabfce",
    "@axonivy/database-editor": "~14.0.0-next.368.5bedf89",
    "@axonivy/database-editor-protocol": "~14.0.0-next.368.5bedf89",
    "@axonivy/dataclass-editor": "~14.0.0-next.915.93eef6a",
    "@axonivy/dataclass-editor-protocol": "~14.0.0-next.915.93eef6a",
    "@axonivy/case-map-editor": "~14.0.0-next.301.f25b70f",
    "@axonivy/case-map-editor-protocol": "~14.0.0-next.301.f25b70f",
    "@axonivy/form-editor": "~14.0.0-next.1228.045750f",
    "@axonivy/form-editor-core": "~14.0.0-next.1228.045750f",
    "@axonivy/form-editor-protocol": "~14.0.0-next.1228.045750f",
    "@axonivy/jsonrpc": "~14.0.0-next.1134.0b6ad82",
    "@axonivy/log-view": "~14.0.0-next.437.97f5bf9",
    "@axonivy/log-view-core": "~14.0.0-next.437.97f5bf9",
    "@axonivy/process-editor": "~14.0.0-next.2193.8e54b8a7",
    "@axonivy/process-editor-inscription-protocol": "~14.0.0-next.2193.8e54b8a7",
    "@axonivy/restclient-editor": "~14.0.0-next.147.961693",
    "@axonivy/restclient-editor-protocol": "~14.0.0-next.147.961693",
    "@axonivy/webservice-editor": "~14.0.0-next.106.3bf39bc",
    "@axonivy/webservice-editor-protocol": "~14.0.0-next.106.3bf39bc",
    "@axonivy/role-editor": "~14.0.0-next.195.4ae7507",
    "@axonivy/role-editor-protocol": "~14.0.0-next.195.4ae7507",
    "@axonivy/ui-components": "~14.0.0-next.1134.0b6ad82",
    "@axonivy/ui-graph": "~14.0.0-next.1134.0b6ad82",
    "@axonivy/ui-icons": "~14.0.0-next.1134.0b6ad82",
    "@axonivy/user-editor": "~14.0.0-next.148.7a29892",
    "@axonivy/user-editor-protocol": "~14.0.0-next.148.7a29892",
    "@axonivy/persistence-editor": "~14.0.0-next.125.062c0b2",
    "@axonivy/persistence-editor-protocol": "~14.0.0-next.125.062c0b2",
    "@axonivy/variable-editor": "~14.0.0-next.1059.d96a35f",
    "@axonivy/variable-editor-protocol": "~14.0.0-next.1059.d96a35f",
    "@eclipse-glsp/protocol": "2.6.0",
    "@react-router/node": "^7.10.1",
    "@tanstack/react-query": "^5.81.0",
    "@tanstack/react-query-devtools": "^5.81.0",
    "i18next": "^26.0.0",
    "i18next-browser-languagedetector": "^8.0.4",
    "i18next-chained-backend": "^5.0.0",
    "i18next-http-backend": "^3.0.2",
    "i18next-resources-to-backend": "^1.2.1",
    "isbot": "^5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.0",
    "react-router": "^7.10.1",
    "vscode-jsonrpc": "8.2.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@axonivy/eslint-config": "~14.0.0-next.1134.0b6ad82",
    "@axonivy/prettier-config": "~14.0.0-next.1134.0b6ad82",
    "@axonivy/ts-config": "~14.0.0-next.1134.0b6ad82",
    "@react-router/dev": "^7.10.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vanilla-extract/recipes": "^0.5.5",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.0.0",
    "happy-dom": "^20.0.0",
    "i18next-cli": "^1.21.1",
    "orval": "8.8.1",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vite-plugin-compression2": "^2.3.1",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "volta": {
    "node": "24.14.1"
  },
  "workspaces": [
    "webviews/process-editor",
    "playwright"
  ],
  "prettier": "@axonivy/prettier-config"
}
