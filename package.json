{
  "name": "@axonivy/neo-root",
  "private": true,
  "version": "14.0.0-next",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "check": "pnpm run type && (pnpm run lint:ci || true) && pnpm run test:ci  && pnpm run i18n:ci",
    "build:ci": "pnpm run build:editor && pnpm run i18n:collect && pnpm run build",
    "build": "react-router build",
    "build:editor": "pnpm run --filter @axonivy/neo-webview-process-editor build",
    "dev": "react-router dev",
    "dev:debug": "export DEBUG=vite:* && remix vite:dev",
    "serve": "vite preview",
    "openapi": "pnpm run openapi:download && pnpm run openapi:codegen",
    "openapi:codegen": "orval",
    "openapi:download": "mvn clean validate && curl -o target/market/openapi.json https://market.axonivy.com/stable/api-docs --create-dirs",
    "lint": "eslint",
    "lint:ci": "eslint -o eslint.xml -f checkstyle",
    "lint:fix": "eslint --fix",
    "lint:inspect": "eslint --inspect-config",
    "i18n": "pnpm run i18n:extract && pnpm run i18n:collect",
    "i18n:collect": "node --experimental-transform-types ./scripts/i18n-collect.ts",
    "i18n:extract": "i18next-cli extract",
    "i18n:ci": "i18next-cli extract --ci --dry-run",
    "test": "vitest",
    "test:ci": "vitest run",
    "playwright": "pnpm run --filter playwright --",
    "type": "react-router typegen && tsc && pnpm run --filter @axonivy/neo-webview-process-editor type && pnpm run --filter @axonivy/neo-playwright type",
    "update:axonivy:next": "npx --yes npm-check-updates @axonivy* -w -c 0 --root -t semver -u",
    "sbom": "pnpm sbom --sbom-format cyclonedx --prod > bom.json",
    "sbom:dev": "pnpm sbom --sbom-format cyclonedx > bom-dev.json"
  },
  "dependencies": {
    "@axonivy/case-map-editor": "~14.0.0-next.334.a798e6a",
    "@axonivy/case-map-editor-protocol": "~14.0.0-next.334.a798e6a",
    "@axonivy/cms-editor": "~14.0.0-next.790.e0672e0",
    "@axonivy/cms-editor-protocol": "~14.0.0-next.790.e0672e0",
    "@axonivy/database-editor": "~14.0.0-next.396.b0e2540",
    "@axonivy/database-editor-protocol": "~14.0.0-next.396.b0e2540",
    "@axonivy/dataclass-editor": "~14.0.0-next.944.18e20be",
    "@axonivy/dataclass-editor-protocol": "~14.0.0-next.944.18e20be",
    "@axonivy/form-editor": "~14.0.0-next.1262.8ed43f4",
    "@axonivy/form-editor-core": "~14.0.0-next.1262.8ed43f4",
    "@axonivy/form-editor-protocol": "~14.0.0-next.1262.8ed43f4",
    "@axonivy/jsonrpc": "~14.0.0-next.1159.2e02135",
    "@axonivy/log-view": "~14.0.0-next.461.50ea2ee",
    "@axonivy/log-view-core": "~14.0.0-next.461.50ea2ee",
    "@axonivy/persistence-editor": "~14.0.0-next.157.43e8f11",
    "@axonivy/persistence-editor-protocol": "~14.0.0-next.157.43e8f11",
    "@axonivy/process-editor": "~14.0.0-next.2232.4d5d5970",
    "@axonivy/process-editor-inscription-protocol": "~14.0.0-next.2232.4d5d5970",
    "@axonivy/restclient-editor": "~14.0.0-next.190.650d9d0",
    "@axonivy/restclient-editor-protocol": "~14.0.0-next.190.650d9d0",
    "@axonivy/role-editor": "~14.0.0-next.227.def9ac9",
    "@axonivy/role-editor-protocol": "~14.0.0-next.227.def9ac9",
    "@axonivy/ui-components": "~14.0.0-next.1159.2e02135",
    "@axonivy/ui-graph": "~14.0.0-next.1159.2e02135",
    "@axonivy/ui-icons": "~14.0.0-next.1159.2e02135",
    "@axonivy/user-editor": "~14.0.0-next.174.c23477e",
    "@axonivy/user-editor-protocol": "~14.0.0-next.174.c23477e",
    "@axonivy/variable-editor": "~14.0.0-next.1087.21063f0",
    "@axonivy/variable-editor-protocol": "~14.0.0-next.1087.21063f0",
    "@axonivy/webservice-editor": "~14.0.0-next.153.388ad43",
    "@axonivy/webservice-editor-protocol": "~14.0.0-next.153.388ad43",
    "@eclipse-glsp/protocol": "2.6.0",
    "@react-router/node": "^7.15.0",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "i18next": "^26.1.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-chained-backend": "^5.0.4",
    "i18next-http-backend": "^4.0.0",
    "i18next-resources-to-backend": "^1.2.1",
    "isbot": "^5.1.40",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.7",
    "react-router": "^7.15.0",
    "vscode-jsonrpc": "8.2.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axonivy/eslint-config": "14.0.0-next.1152.43581ef",
    "@axonivy/prettier-config": "14.0.0-next.1152.43581ef",
    "@axonivy/ts-config": "14.0.0-next.1152.43581ef",
    "@react-router/dev": "^7.15.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/recipes": "^0.5.7",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "i18next-cli": "^1.56.12",
    "orval": "8.16.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-compression2": "^2.5.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "volta": {
    "node": "24.14.1"
  },
  "workspaces": [
    "webviews/process-editor",
    "playwright"
  ],
  "prettier": "@axonivy/prettier-config"
}
